config opencellid 'main'
	option enabled '0'
	option interval '300'
	option heartbeat_interval '3600'
	option publish_on_change '1'
	option cache_ttl '86400'
	option backoff_initial '30'
	option backoff_max '900'
	option queue_size '10'
	option opencellid_url 'https://opencellid.org/cell/get'
	option opencellid_key ''
	option reverse_geocode '1'
	option geocode_min_interval '60'
	option geocode_url 'https://nominatim.openstreetmap.org/reverse'
	option mqtt_host ''
	option mqtt_port '8883'
	option mqtt_topic 'zlan9809m/location'
	option mqtt_client_id 'zlan9809m'
	option mqtt_username ''
	option mqtt_password ''
	option mqtt_tls '1'
	option mqtt_insecure '0'
	option mqtt_retain '1'
	option mqtt_status_topic 'zlan9809m/status'
	option mqtt_will '1'
	option mqtt_ca_file ''
	option mqtt_cert_file ''
	option mqtt_key_file ''
	option cell_source 'auto'
	option modem_device '/dev/ttyUSB2'
	option qmi_device '/dev/cdc-wdm0'
	option manual_mcc ''
	option manual_mnc ''
	option manual_lac ''
	option manual_cid ''
	option manual_radio 'LTE'
	option at_adapter 'auto'
	option wwan_interface 'wwan'
	option zlan_mnc_length '2'
	option zlan_values_hex '0'
